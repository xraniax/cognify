# Backend service environment

# Server
PORT=5000
NODE_ENV=development

# Required: database connection (must match engine/db service values)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_postgres_password
DB_NAME=elearning

# Required: backend auth + engine integration
JWT_SECRET=change_me_jwt_secret
ENGINE_URL=http://engine:8000
FRONTEND_URL=http://localhost:3000
PDF_STORAGE_PATH=/app/data/uploads

# Optional: session secret (recommended in production)
SESSION_SECRET=change_me_session_secret
BACKEND_URL=http://localhost:5000

# Optional OAuth integrations (leave empty to disable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional SMTP integration (leave empty to disable email reset flow)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
