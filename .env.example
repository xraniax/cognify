# Root orchestration env (docker-compose + frontend public API URL)

# Backend Secrets
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Ollama (engine embeddings + health check; Docker service name ollama)
OLLAMA_BASE_URL=http://ollama:11434
# Optional full URL override (defaults to ${OLLAMA_BASE_URL}/api/embeddings)
# OLLAMA_EMBEDDINGS_URL=http://ollama:11434/api/embeddings
OLLAMA_MODEL=llama3.1:8b

# Service URLs (Docker service names)
ENGINE_URL=http://engine:8000
FRONTEND_URL=http://frontend:3000

# OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth (GitHub)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# Environment
NODE_ENV=development
PORT=5000

# Frontend (Vite)
VITE_API_URL=http://backend:5000/api

# PostgreSQL (for db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=elearning

# Frontend runtime API URL (browser-side)
VITE_API_URL=http://localhost:5000/api

# Optional Google Drive integration (engine)
# Preferred (production-safe): base64-encoded service account JSON
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
# Development-only fallback: local credentials file path
GOOGLE_SERVICE_ACCOUNT_FILE=